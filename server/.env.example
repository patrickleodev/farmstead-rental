NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200,http://localhost:8080,capacitor://localhost,http://localhost,https://localhost

# Google login and administrator access.
# Generate a secure value with at least 32 characters for AUTH_JWT_SECRET.
GOOGLE_CLIENT_ID=
AUTH_JWT_SECRET=
ADMIN_EMAILS=admin@example.com

# Local development database.
# For Docker Compose, docker-compose.yml overrides DB_HOST to the database service.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=farmstead_rental
DB_SCHEMA=public

DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
TYPEORM_SYNC=false
TYPEORM_LOGGING=false
TYPEORM_MIGRATIONS_RUN=false

# Production Supabase example:
# NODE_ENV=production
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# DB_SSL=true
# TYPEORM_MIGRATIONS_RUN=true
