{
  "name": "farmstead-rental",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack app to manage farmstead rentals.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run start:dev -w server\" \"npm run start -w client\"",
    "dev:client": "npm run start -w client",
    "dev:server": "npm run start:dev -w server",
    "build": "npm run build -w server && npm run build -w client",
    "test:server": "npm run test -w server",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "mobile:sync": "npm run mobile:sync -w client",
    "mobile:android": "npm run mobile:android -w client",
    "mobile:ios": "npm run mobile:ios -w client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
